# Copy this file to `.env` or use `php_app/config.local.php` for local overrides.
# Never commit real secrets to Git.

UTHENGA_ENV=production
UTHENGA_BASE_URL=https://your-domain.com/

DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=
DB_NAME=uthenga_db
DB_USER=uthenga_user
DB_PASS=your_db_password

# Optional legacy aliases supported by config.php
UTHENGA_DB_HOST=localhost
UTHENGA_DB_PORT=3306
UTHENGA_DB_SOCKET=
UTHENGA_DB_NAME=uthenga_db
UTHENGA_DB_USER=uthenga_user
UTHENGA_DB_PASS=your_db_password

UTHENGA_SUPPORT_EMAIL=support@your-domain.com
UTHENGA_MAIL_FROM_EMAIL=support@your-domain.com
UTHENGA_MAIL_FROM_NAME=Uthenga
UTHENGA_PASSWORD_RESET_TTL_MINUTES=60

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
